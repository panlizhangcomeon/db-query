# Copy to .env and fill in locally. Never commit .env.

# LLM（自然语言查询必填）
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 可选：元数据 SQLite 路径（默认 ~/.db_query/db_query.db）
# DB_QUERY_SQLITE_PATH=

# 可选：CORS，开发期可用 *
# CORS_ORIGINS=*

# 可选：限制每张表传给 LLM 的列数（默认不限制，避免漏掉 add_time 等列导致乱造 create_time）
# LLM_SCHEMA_MAX_COLUMNS=50
